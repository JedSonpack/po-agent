# API Key (required) — ARK (Volcengine) Anthropic-compatible endpoint
ANTHROPIC_API_KEY=ark-xxxxxxxx

# Anthropic-compatible base URL (required for ARK)
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding

# Model ID (required) — /api/coding 端点支持 glm-5.2；glm-5.1 会返回 404 UnsupportedModel
MODEL_ID=glm-5.2
